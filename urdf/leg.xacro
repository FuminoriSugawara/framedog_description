  <!--
    framedog_leg: one 3-DOF leg.
      prefix  : link/joint name prefix (lf, rf, lr, rr)
      side    : 'left' or 'right'
      parent  : body link the leg is bolted to
      mesh_pkg: base URI for meshes
      *origin : FIXED mount transform (parent_link -> leg base)
    body -[fixed]- roll_holder -[roll]- pitch_holder -[pitch]- thigh
          -[knee]- knee_crank ; thigh -[calf, mimic(knee)]- calf -[fixed]- tip.
    Active joint axes = child link +Z. Joint position limits are in degrees via
    radians(); effort (N*m) / velocity (rad/s) are rough placeholders.
  -->
  <xacro:macro name="framedog_leg" params="prefix side parent mesh_pkg:=package://framedog_description/meshes knee_mimic:=1.0 coupler_mimic:=1.0 thigh_zflip:=false *origin">
    <xacro:property name="L" value="${side == 'left'}"/>
    <xacro:property name="md" value="${mesh_pkg}/leg"/>

    <xacro:macro name="leg_link" params="name mesh m com I material:=framedog_dark">
      <link name="${name}">
        <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="${md}/${mesh}.stl" scale="0.001 0.001 0.001"/></geometry>
          <material name="${material}"/>
        </visual>
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="${md}/${mesh}.stl" scale="0.001 0.001 0.001"/></geometry>
        </collision>
        <inertial>
          <origin xyz="${com}" rpy="0 0 0"/>
          <mass value="${m}"/>
          <inertia ixx="${I.split()[0]}" ixy="${I.split()[1]}" ixz="${I.split()[2]}"
                   iyy="${I.split()[3]}" iyz="${I.split()[4]}" izz="${I.split()[5]}"/>
        </inertial>
      </link>
    </xacro:macro>

    <!-- links -->
    <xacro:leg_link name="${prefix}_roll_holder_link"  mesh="leg_roll_motor_holder"  m="${L_rollh_m if L else R_rollh_m}"  com="${L_rollh_com if L else R_rollh_com}"  I="${L_rollh_I if L else R_rollh_I}"/>
    <xacro:leg_link name="${prefix}_pitch_holder_link" mesh="leg_pitch_motor_holder" m="${L_pitchh_m if L else R_pitchh_m}" com="${L_pitchh_com if L else R_pitchh_com}" I="${L_pitchh_I if L else R_pitchh_I}"/>
    <xacro:leg_link name="${prefix}_thigh_link"        mesh="leg_thigh"              m="${L_thigh_m if L else R_thigh_m}"  com="${L_thigh_com if L else R_thigh_com}"  I="${L_thigh_I if L else R_thigh_I}"/>
    <xacro:leg_link name="${prefix}_knee_crank_link"   mesh="leg_knee_crank_${side}" m="${L_crank_m if L else R_crank_m}"  com="${L_crank_com if L else R_crank_com}"  I="${L_crank_I if L else R_crank_I}"  material="framedog_accent"/>
    <xacro:leg_link name="${prefix}_calf_link"         mesh="leg_calf"               m="${L_calf_m if L else R_calf_m}"   com="${L_calf_com if L else R_calf_com}"   I="${L_calf_I if L else R_calf_I}"/>
    <xacro:leg_link name="${prefix}_tip_link"          mesh="leg_tip"                m="${L_tip_m if L else R_tip_m}"    com="${L_tip_com if L else R_tip_com}"    I="${L_tip_I if L else R_tip_I}"   material="framedog_accent"/>
    <xacro:leg_link name="${prefix}_knee_coupler_link" mesh="leg_knee_coupler"       m="${L_coupler_m if L else R_coupler_m}" com="${L_coupler_com if L else R_coupler_com}" I="${L_coupler_I if L else R_coupler_I}"/>

    <!-- parent -> leg base (external mount), then base -> roll holder. The root
         transform is identity for the left leg and a 180-deg-X flip for the right,
         so the (shared) roll-holder mesh lands on the correct side. -->
    <link name="${prefix}_base_link"/>
    <joint name="${prefix}_mount_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/><child link="${prefix}_base_link"/>
    </joint>
    <joint name="${prefix}_root_joint" type="fixed">
      <origin xyz="${L_root_xyz if L else R_root_xyz}" rpy="${L_root_rpy if L else R_root_rpy}"/>
      <parent link="${prefix}_base_link"/><child link="${prefix}_roll_holder_link"/>
    </joint>

    <!-- active #1 (roll motor): roll holder -> pitch holder -->
    <joint name="${prefix}_roll_joint" type="revolute">
      <origin xyz="${L_roll_xyz if L else R_roll_xyz}" rpy="${L_roll_rpy if L else R_roll_rpy}"/>
      <parent link="${prefix}_roll_holder_link"/><child link="${prefix}_pitch_holder_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="${radians(-90)}" upper="${radians(90)}" effort="17" velocity="20"/>
    </joint>

    <!-- active #2 (pitch motor): pitch holder -> thigh.
         thigh_zflip rotates the thigh (and the lower leg it carries) 180 deg about Z. -->
    <joint name="${prefix}_pitch_joint" type="revolute">
      <origin xyz="${L_pitch_xyz if L else R_pitch_xyz}" rpy="${(L_pitchflip_rpy if L else R_pitchflip_rpy) if thigh_zflip else (L_pitch_rpy if L else R_pitch_rpy)}"/>
      <parent link="${prefix}_pitch_holder_link"/><child link="${prefix}_thigh_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="${radians(-90)}" upper="${radians(90)}" effort="17" velocity="20"/>
    </joint>

    <!-- active #3 (knee motor): thigh -> knee crank -->
    <joint name="${prefix}_knee_joint" type="revolute">
      <origin xyz="${L_knee_xyz if L else R_knee_xyz}" rpy="${L_knee_rpy if L else R_knee_rpy}"/>
      <parent link="${prefix}_thigh_link"/><child link="${prefix}_knee_crank_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="${radians(-50) if L else radians(-35)}" upper="${radians(35) if L else radians(50)}" effort="17" velocity="20"/>
    </joint>

    <!-- calf follows the knee crank (4-bar linkage approximated by a mimic) -->
    <joint name="${prefix}_calf_joint" type="revolute">
      <origin xyz="${L_calf_xyz if L else R_calf_xyz}" rpy="${L_calf_rpy if L else R_calf_rpy}"/>
      <parent link="${prefix}_thigh_link"/><child link="${prefix}_calf_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="${radians(-180)}" upper="${radians(180)}" effort="0" velocity="20"/>
      <mimic joint="${prefix}_knee_joint" multiplier="${knee_mimic}" offset="0"/>
    </joint>

    <joint name="${prefix}_tip_joint" type="fixed">
      <origin xyz="${L_tip_xyz if L else R_tip_xyz}" rpy="${L_tip_rpy if L else R_tip_rpy}"/>
      <parent link="${prefix}_calf_link"/><child link="${prefix}_tip_link"/>
    </joint>

    <!-- knee coupler: child of the crank so its origin travels with the crank tip,
         while its orientation tracks the thigh (stays parallel to the ground link). -->
    <joint name="${prefix}_coupler_joint" type="revolute">
      <origin xyz="${L_coupler_xyz if L else R_coupler_xyz}" rpy="${L_coupler_rpy if L else R_coupler_rpy}"/>
      <parent link="${prefix}_knee_crank_link"/><child link="${prefix}_knee_coupler_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="${radians(-180)}" upper="${radians(180)}" effort="0" velocity="20"/>
      <mimic joint="${prefix}_knee_joint" multiplier="${coupler_mimic}" offset="0"/>
    </joint>
  </xacro:macro>
</robot>
